# ════════════════════════════════════════
# Кафе #ДОМ — переменные окружения
# Скопируйте этот файл в .env и заполните значения
# ════════════════════════════════════════

# YooKassa — получить в личном кабинете yookassa.ru
# Настройки → API-ключи
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Telegram бот (уже заполнены)
TELEGRAM_BOT_TOKEN=8643611676:AAGgbJh1HIaOPJkfL9bvLGcevp4XuePT4D8
TELEGRAM_CHAT_ID=829247940

# Публичный URL вашего сайта (без слеша в конце)
# На Railway это будет что-то вроде: https://dom-cafe.up.railway.app
BASE_URL=https://your-app.up.railway.app

# Порт (Railway задаёт автоматически)
PORT=3000
